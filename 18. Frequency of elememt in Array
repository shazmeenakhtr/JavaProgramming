class Freq {
    public static void main(String[] args) {

        int a[] = {1, 2, 2, 3, 1, 4};
        int n = a.length;

        int count[] = new int[n];
        boolean used[] = new boolean[n];

        for (int i = 0; i < n; i++) {
            if (used[i] == true)
                continue;

            int c = 1;

            for (int j = i + 1; j < n; j++) {
                if (a[i] == a[j]) {
                    c++;
                    used[j] = true;
                }
            }

            System.out.println(a[i] + " = " + c);
        }
    }
}
