import java.util.Scanner;

class Item {
    int code;
    double price;

    void input() {
        Scanner sc = new Scanner(System.in);
        code = sc.nextInt();
        price = sc.nextDouble();
    }

    void display() {
        System.out.println(code + "\t" + price);
    }
}

public class Main {
    public static void main(String[] args) {
        Item[] items = new Item[5];
        double total = 0;

        for (int i = 0; i < 5; i++) {
            items[i] = new Item();
            items[i].input();
        }

        System.out.println("Code\tPrice");

        for (int i = 0; i < 5; i++) {
            items[i].display();
            total += items[i].price;
        }

        System.out.println("Total Price = " + total);
    }
}
